# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/nexus?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_access_secret_key_minimum_32_characters
JWT_EXPIRE=15m
REFRESH_SECRET=your_jwt_refresh_secret_key_minimum_32_characters
REFRESH_EXPIRE=7d

# Session & Cookie
SESSION_SECRET=your_session_secret_key
COOKIE_SECURE=false # Set to true in production

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe (Payment Simulation Sandbox)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SMTP / Nodemailer (OTP & Notifications)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@nexus-platform.com

# Gemini API Key for Help AI support assistant chatbot

VITE_GEMINI_API_KEY=AQ.VITE_GEMINI_API_KEY
